# Copiá este archivo a .env y completá los valores.
# NUNCA subas .env al repositorio (está en .gitignore).

# ====== Dominio / HTTPS ======
# Dominio público de Chatwoot. Apuntá un registro DNS A de este dominio al IP del VPS.
CHATWOOT_DOMAIN=chat.tudominio.com
FRONTEND_URL=https://chat.tudominio.com
# Email para los certificados Let's Encrypt (Caddy)
ACME_EMAIL=comercial@hierbasdeloasis.com.ar

# ====== Secreto de Rails ======
# Generar con:  openssl rand -hex 64
SECRET_KEY_BASE=REEMPLAZAR_openssl_rand_hex_64

# ====== Postgres (compartido Chatwoot + bot) ======
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=CAMBIAR_password_postgres
POSTGRES_DATABASE=chatwoot

# ====== Redis ======
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CAMBIAR_password_redis

# ====== Chatwoot / Rails ======
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
ACTIVE_STORAGE_SERVICE=local
DEFAULT_LOCALE=es
# Dejar en true SOLO para crear el primer usuario admin; luego poner false y reiniciar.
ENABLE_ACCOUNT_SIGNUP=false
# Permite que Chatwoot entregue el webhook del Agent Bot a una IP privada (el bot
# está en la red interna de Docker como http://bot:3000). Sin esto, el filtro SSRF
# de Chatwoot rechaza la URL ("Hostname 'bot' has no public ip addresses").
SAFE_FETCH_ALLOW_PRIVATE_NETWORK=true

# ====== Email (SMTP) — para invitar vendedores y resetear contraseñas ======
MAILER_SENDER_EMAIL=Hierbas del Oasis <comercial@hierbasdeloasis.com.ar>
SMTP_DOMAIN=hierbasdeloasis.com.ar
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true

# ====== Bot (oasis-whatsapp-bot) ======
PORT=3000
# Verify token para el endpoint de debug /meta/webhook (lo elegís vos)
META_VERIFY_TOKEN=oasis-verify-token
# Base de datos propia del bot (misma instancia de Postgres, otra DB).
# NO definir DATABASE_URL en este .env compartido: Chatwoot (Rails) le da prioridad
# por sobre POSTGRES_DATABASE y migraría en la base equivocada. Se define SOLO para el
# servicio 'bot' en docker-compose.yml (a partir de POSTGRES_USERNAME/PASSWORD).
# Chatwoot, accesible por la red interna de Docker
CHATWOOT_BASE_URL=http://rails:3000
# Se completan en la Fase 2 (al crear el Agent Bot y conectar el LLM)
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=
# ID del inbox de WhatsApp (Settings → Inboxes en Chatwoot; usualmente 1)
CHATWOOT_INBOX_ID=1
ANTHROPIC_API_KEY=

# ====== Tango Nexo (Fase 3 — sync de clientes) ======
# Token de acceso de la API de Tango Tiendas (Nexo)
TANGO_ACCESS_TOKEN=
# URL base de la API (no cambiar salvo entornos custom)
TANGO_API_BASE_URL=https://tiendas.axoft.com
