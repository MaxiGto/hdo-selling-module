{
	email {$ACME_EMAIL}
}

# Chatwoot servido con HTTPS automático (Let's Encrypt).
# El bot NO se publica excepto el endpoint de eventos para webhooks de Chatwoot.
{$CHATWOOT_DOMAIN} {
	# Webhook de eventos (conversation_status_changed, etc.) → bot
	handle /bot/events {
		reverse_proxy bot:3000/chatwoot/events
	}

	reverse_proxy rails:3000
}
